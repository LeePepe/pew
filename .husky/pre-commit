#!/usr/bin/env sh

# L1: Unit Tests + Coverage (90% threshold enforced by vitest.config.ts)
bun run test:coverage 2>&1
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
  echo "❌ L1 FAILED: Unit tests or coverage threshold (90%) not met."
  exit 1
fi

# L2: TypeScript strict type checking + ESLint (zero errors, zero warnings)
bun run lint 2>&1
LINT_EXIT=$?

if [ $LINT_EXIT -ne 0 ]; then
  echo "❌ L2 FAILED: Type check or lint failed."
  exit 1
fi

echo "✅ L1 (UT + Coverage ≥90%) + L2 (Lint) passed."
