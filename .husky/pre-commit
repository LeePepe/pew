#!/usr/bin/env sh

# pre-commit: L1 Unit/Component + G1 Static Analysis (quality system)

# G0: Verify lockfile is in sync with package.json (catches missing workspace deps)
# This mirrors CI's `bun install --frozen-lockfile` check
bun install --frozen-lockfile 2>&1
LOCK_EXIT=$?

if [ $LOCK_EXIT -ne 0 ]; then
  echo "❌ pre-commit FAILED: Lockfile out of sync. Run 'bun install' and commit bun.lock."
  exit 1
fi

# L1 Unit/Component: coverage ≥90% enforced by vitest.config.ts
bun run test:coverage 2>&1
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
  echo "❌ pre-commit FAILED: Unit tests or coverage threshold (90%) not met."
  exit 1
fi

# G1a Static Analysis: TypeScript strict (full project — tsc needs complete context)
bun run lint:typecheck 2>&1
TSC_EXIT=$?

if [ $TSC_EXIT -ne 0 ]; then
  echo "❌ pre-commit FAILED: TypeScript type check errors."
  exit 1
fi

# G1b Static Analysis: ESLint strict (staged files only, via lint-staged)
bunx lint-staged 2>&1
LINT_EXIT=$?

if [ $LINT_EXIT -ne 0 ]; then
  echo "❌ pre-commit FAILED: ESLint errors in staged files."
  exit 1
fi

echo "✅ pre-commit passed: G0 Lockfile + L1 Unit ≥90% + G1 Static Analysis"
